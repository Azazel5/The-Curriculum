# Copy to .env for local development (optional). On Render, set these in the dashboard.

# Flask CLI (local migrations / shell)
FLASK_APP=app:create_app

# Local dev only — ProductionConfig on Render reads from host env, not this file.
SECRET_KEY=change-me-local-only

# Leave unset locally to use SQLite in instance/curriculum.db.
# Neon: use the connection string from the Neon console (include sslmode=require if not already).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
